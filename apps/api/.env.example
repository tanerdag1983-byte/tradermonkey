# Application
APP_ENV=development
APP_NAME=TraderMonkeys API
DEBUG=true
LOG_LEVEL=info

# Server
PORT=8000
HOST=0.0.0.0

# Database (for local Docker development)
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/tradermonkeys

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Trading 212 (DEMO - use demo.trading212.com)
# DO NOT commit real keys to git
T212_API_KEY=your-t212-api-key
T212_API_SECRET=your-t212-api-secret
T212_BASE_URL=https://demo.trading212.com

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional Sentry / monitoring
SENTRY_DSN=
