# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Trading 212 DEMO
# Kopieer je keys hier; deze file is .gitignored
T212_API_KEY=your-t212-api-key
T212_API_SECRET=your-t212-api-secret
T212_BASE_URL=https://demo.trading212.com

# Alpaca paper trading
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key

# Database (for local Docker development)
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/tradermonkeys

# Application
APP_ENV=development
ENABLE_SCHEDULER=false
SCHEDULER_USER_ID=scheduler
SCHEDULER_NEWS_INTERVAL_MINUTES=60
SCHEDULER_SIGNALS_TIME=09:30
SCHEDULER_SIGNALS_TIMEZONE=US/Eastern
SCHEDULER_DEFAULT_WATCHLIST=AAPL,MSFT,AMZN,GOOGL,META,TSLA,NVDA,AMD,INTC,NFLX,CRM,BABA,JPM,V,MA,DIS

# Research defaults used by the scheduler
RESEARCH_DEFAULT_BUDGET=1000.0
RESEARCH_DEFAULT_CURRENCY=EUR
RESEARCH_DEFAULT_RISK_PROFILE=moderate

# Optional prompt override file paths
SIGNAL_PROMPT_OVERRIDE_PATH=
RESEARCH_PROMPT_OVERRIDE_PATH=

# Frontend
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
# For Vercel production, set this to your Render API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional
SENTRY_DSN=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SIGNAL_PROMPT_OVERRIDE_PATH=

# Email notifications (Resend)
RESEND_API_KEY=your-resend-api-key
NOTIFICATION_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_EMAIL=onboarding@resend.dev
ADMIN_EMAIL=your-admin-email
ENABLE_EMAIL_DIGEST=false
